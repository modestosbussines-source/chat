# ============================================
# Omni - Variáveis de Ambiente de Produção
# ============================================
# Copie este arquivo para .env e preencha os valores
# ⚠️ NUNCA commite o arquivo .env!

# --------------------------------------------
# App
# --------------------------------------------
OMNI_APP_ENVIRONMENT=production
OMNI_APP_ENCRYPTION_KEY=  # Gerar: openssl rand -base64 32

# --------------------------------------------
# Database (PostgreSQL)
# --------------------------------------------
OMNI_DATABASE_HOST=db
OMNI_DATABASE_PORT=5432
OMNI_DATABASE_USER=omni
OMNI_DATABASE_PASSWORD=  # Gerar senha forte
OMNI_DATABASE_NAME=omni
OMNI_DATABASE_SSL_MODE=require

# --------------------------------------------
# Redis
# --------------------------------------------
OMNI_REDIS_HOST=redis
OMNI_REDIS_PORT=6379
OMNI_REDIS_PASSWORD=  # Gerar senha forte

# --------------------------------------------
# JWT
# --------------------------------------------
OMNI_JWT_SECRET=  # Gerar: openssl rand -base64 64

# --------------------------------------------
# Server
# --------------------------------------------
OMNI_SERVER_ALLOWED_ORIGINS=https://omni.seudominio.com

# --------------------------------------------
# WhatsApp (Meta)
# --------------------------------------------
OMNI_WHATSAPP_WEBHOOK_VERIFY_TOKEN=  # Gerar token aleatório
OMNI_WHATSAPP_API_VERSION=v21.0

# --------------------------------------------
# Calling (WebRTC)
# --------------------------------------------
OMNI_CALLING_PUBLIC_IP=  # IP público da VPS

# --------------------------------------------
# Admin Inicial (apenas primeiro acesso)
# --------------------------------------------
OMNI_DEFAULT_ADMIN_EMAIL=admin@seudominio.com
OMNI_DEFAULT_ADMIN_PASSWORD=  # Usar senha forte! Mude após primeiro login.
OMNI_DEFAULT_ADMIN_FULL_NAME=Administrator

# --------------------------------------------
# Docker Compose variáveis
# --------------------------------------------
POSTGRES_USER=omni
POSTGRES_PASSWORD=  # Mesmo valor de OMNI_DATABASE_PASSWORD
POSTGRES_DB=omni

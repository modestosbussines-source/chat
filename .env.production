# ============================================
# Omni - Environment Variables for Production
# ============================================
# COPY this file to .env and fill in the values
# ⚠️ NEVER commit .env to version control!

# --------------------------------------------
# APP
# --------------------------------------------
OMNI_APP_ENVIRONMENT=production
# Generate: openssl rand -base64 32
OMNI_APP_ENCRYPTION_KEY=

# --------------------------------------------
# Database (PostgreSQL)
# --------------------------------------------
OMNI_DATABASE_HOST=db
OMNI_DATABASE_PORT=5432
OMNI_DATABASE_USER=omni
# Generate: openssl rand -base64 32
OMNI_DATABASE_PASSWORD=
OMNI_DATABASE_NAME=omni
OMNI_DATABASE_SSL_MODE=require

# --------------------------------------------
# Redis
# --------------------------------------------
OMNI_REDIS_HOST=redis
OMNI_REDIS_PORT=6379
# Generate: openssl rand -base64 32
OMNI_REDIS_PASSWORD=

# --------------------------------------------
# JWT
# --------------------------------------------
# Generate: openssl rand -base64 64 (must be 32+ chars)
OMNI_JWT_SECRET=

# --------------------------------------------
# Server
# --------------------------------------------
OMNI_SERVER_ALLOWED_ORIGINS=https://your-domain.com

# --------------------------------------------
# WhatsApp (Meta)
# --------------------------------------------
# Generate: openssl rand -hex 32
OMNI_WHATSAPP_WEBHOOK_VERIFY_TOKEN=
OMNI_WHATSAPP_API_VERSION=v21.0

# --------------------------------------------
# Calling (WebRTC) - Optional
# --------------------------------------------
# OMNI_CALLING_PUBLIC_IP=your-public-ip

# --------------------------------------------
# Initial Admin (only for first login)
# --------------------------------------------
OMNI_DEFAULT_ADMIN_EMAIL=admin@your-domain.com
# Generate a strong password!
OMNI_DEFAULT_ADMIN_PASSWORD=
OMNI_DEFAULT_ADMIN_FULL_NAME=Administrator

# --------------------------------------------
# Docker Compose variables
# --------------------------------------------
POSTGRES_USER=omni
# Same as OMNI_DATABASE_PASSWORD
POSTGRES_PASSWORD=
POSTGRES_DB=omni
REDIS_PASSWORD=

# ============================================
# COMMANDS TO GENERATE SECRETS
# ============================================
# Run these commands to generate secure values:
#
# Encryption Key (32 bytes):
#   openssl rand -base64 32
#
# JWT Secret (64 bytes):
#   openssl rand -base64 64
#
# Database/Redis Password:
#   openssl rand -base64 32
#
# Webhook Verify Token:
#   openssl rand -hex 32
#
# Strong Admin Password (12+ chars):
#   openssl rand -base64 16 | tr -dc 'A-Za-z0-9!@#$%^&*' | head -c 16